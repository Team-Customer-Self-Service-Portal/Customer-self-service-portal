{
  "name": "customer-self-service-backend",
  "version": "1.0.0",
  "description": "Customer Self-Service Portal backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc -p tsconfig.json",
